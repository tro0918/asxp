{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://asxp.org/schema/0.1/skill-manifest.schema.json",
  "title": "ASXP Skill Manifest",
  "type": "object",
  "required": ["protocolVersion", "name", "description", "version", "instructions", "tools"],
  "properties": {
    "protocolVersion": {"const": "0.1"},
    "id": {"type": "string", "format": "uri"},
    "name": {"type": "string", "pattern": "^[a-z0-9](?:[a-z0-9-]{0,62}[a-z0-9])?$"},
    "description": {"type": "string", "minLength": 1, "maxLength": 4096},
    "version": {"type": "string", "pattern": "^[0-9]+\\.[0-9]+\\.[0-9]+(?:[-+][0-9A-Za-z.-]+)?$"},
    "revision": {"type": "string", "minLength": 1},
    "publisher": {"type": "string"},
    "license": {"type": "string"},
    "instructions": {"type": "string", "maxLength": 262144},
    "tools": {"type": "array", "maxItems": 128, "items": {"$ref": "tool.schema.json"}},
    "permissions": {"type": "array", "items": {"type": "string"}, "uniqueItems": true},
    "privacy": {"enum": ["local", "delegated", "external"]},
    "origin": {
      "type": "object",
      "required": ["url"],
      "properties": {
        "url": {"type": "string", "format": "uri"},
        "delegationUrl": {"type": "string", "format": "uri"}
      },
      "additionalProperties": false
    },
    "extensions": {"type": "object"}
  },
  "additionalProperties": true
}
